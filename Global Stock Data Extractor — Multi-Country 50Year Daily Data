def get_suffix(country_code: str) -> str:
    """Look up the yfinance exchange suffix for a 2-letter country code."""
    return EXCHANGE_SUFFIX.get(country_code.upper(), "")


# ─── PERSISTENT TICKER CACHE ──────────────────────────────────────────────────

def load_cache() -> dict:
    if os.path.exists(CACHE_FILE):
        with open(CACHE_FILE, "r") as f:
            return json.load(f)
    return {}

def save_cache(cache: dict):
    with open(CACHE_FILE, "w") as f:
        json.dump(cache, f, indent=2)

def update_cache(index_name: str, tickers: list):
    """Merge new tickers into the cache for this index (no duplicates)."""
    cache = load_cache()
    existing = set(cache.get(index_name, []))
    merged = sorted(existing | set(tickers))
    cache[index_name] = merged
    save_cache(cache)
    log.info(f"   Cache updated for {index_name}: {len(merged)} tickers stored")
    return merged

def get_cached_tickers(index_name: str) -> list:
    cache = load_cache()
    return cache.get(index_name, [])


# ─── WIKIPEDIA SCRAPING ───────────────────────────────────────────────────────

# All known column name variants across different Wikipedia pages
TICKER_COLUMN_CANDIDATES = [
    "Ticker", "ticker", "Symbol", "symbol", "Code", "code",
    "Ticker symbol", "Stock symbol", "ISIN", "Mnemonic",
    "Abbreviation", "Short name", "Listing code"
]

def scrape_wikipedia_tickers(url: str, suffix: str, col_hints: list = None) -> list:
    """
    Scrape tickers from a Wikipedia index page.
    Tries multiple known column name variants. Returns tickers with suffix applied.
    """
    candidates = col_hints or TICKER_COLUMN_CANDIDATES
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=15) as resp:
            raw = resp.read()
        tables = pd.read_html(io.BytesIO(raw))
        
        # Try tables from largest to smallest (skip tiny nav tables)
        tables_sorted = sorted(tables, key=len, reverse=True)
        
        for table in tables_sorted[:5]:   # check top 5 largest tables
            for col in candidates:
                if col in table.columns:
                    raw_tickers = table[col].dropna().astype(str).tolist()
                    # Clean and apply suffix
                    tickers = []
                    for t in raw_tickers:
                        t = t.strip().split(" ")[0]   # remove trailing footnotes
                        t = t.replace(" ", "").replace("\xa0", "")
                        if t and not t.startswith("0") and len(t) <= 10:
                            tickers.append(t + suffix if not t.endswith(suffix) else t)
                    if tickers:
                        log.info(f"   Wikipedia: found {len(tickers)} tickers via column '{col}'")
                        return tickers
        log.warning(f"   Wikipedia: no matching ticker column found in {url}")
    except Exception as e:
        log.warning(f"   Wikipedia scrape failed: {e}")
    return []


# ─── MARKET CAP RANKING (BATCH) ───────────────────────────────────────────────

def rank_by_market_cap(tickers: list) -> list:
    """
    Fetch market caps in batches and return tickers sorted by market cap descending.
    Much faster than calling yf.Ticker(t).info one-by-one.
    """
    log.info(f"   Ranking {len(tickers)} tickers by market cap (batch fetch)...")
    cap_map = {}

    # yf.download with a short period is fastest way to confirm tickers exist
    # Then fetch .fast_info (lightweight) for market cap
    for i in range(0, len(tickers), DOWNLOAD_CHUNK):
        chunk = tickers[i : i + DOWNLOAD_CHUNK]
        for t in chunk:
            try:
                fi = yf.Ticker(t).fast_info
                cap = getattr(fi, "market_cap", None) or 0
                if cap > 0:
                    cap_map[t] = cap
            except Exception:
                pass
        time.sleep(0.5)   # gentle rate limiting

    ranked = sorted(cap_map, key=cap_map.get, reverse=True)
    unranked = [t for t in tickers if t not in cap_map]
    log.info(f"   Ranked: {len(ranked)} valid | Skipped (no cap data): {len(unranked)}")
    return ranked + unranked   # valid ones first, then unknowns at the end


# ─── DOWNLOAD WITH RETRY ──────────────────────────────────────────────────────

def download_with_retry(tickers: list, start: str, end: str) -> pd.DataFrame:
    """Download historical close prices with retry on failure."""
    for attempt in range(1, RETRY_ATTEMPTS + 1):
        try:
            data = yf.download(
                tickers,
                start=start,
                end=end,
                auto_adjust=True,
                progress=False,
                threads=True
            )
            if isinstance(data.columns, pd.MultiIndex):
                close = data["Close"]
            else:
                close = data
            return close
        except Exception as e:
            log.warning(f"   Download attempt {attempt} failed: {e}")
            if attempt < RETRY_ATTEMPTS:
                time.sleep(RETRY_DELAY * attempt)
    log.error("   All download attempts failed. Returning empty DataFrame.")
    return pd.DataFrame()


# ─── MAIN EXTRACTOR ───────────────────────────────────────────────────────────

def extract_country_data(job: dict):
    """
    Full pipeline for one country/index:
      1. Load cached tickers (from previous runs)
      2. Scrape Wikipedia for new tickers
      3. Merge with manual list
      4. Update cache
      5. Rank by market cap
      6. Download 50-year daily data
      7. Export transposed CSV (tickers on Y-axis, dates on X-axis)
    """
    country    = job["country"]
    index_name = job["index_name"]
    suffix     = get_suffix(job.get("country_code", ""))
    log.info(f"\n{'='*60}")
    log.info(f"PROCESSING: {country} — {index_name}")

    # Step 1: cached tickers from previous runs
    cached = get_cached_tickers(index_name)
    log.info(f"   Cache: {len(cached)} previously known tickers")

    # Step 2: Wikipedia auto-scrape
    auto = []
    if job.get("url"):
        auto = scrape_wikipedia_tickers(
            url=job["url"],
            suffix=suffix,
            col_hints=job.get("cols")
        )

    # Step 3: merge cached + auto + manual (no duplicates)
    manual  = job.get("manual", [])
    combined = list(set(cached) | set(auto) | set(manual))
    log.info(f"   Combined (cached + auto + manual): {len(combined)} unique tickers")

    # Step 4: persist back to cache
    combined = update_cache(index_name, combined)

    # Step 5: rank by market cap
    ranked = rank_by_market_cap(combined)

    # Step 6: download historical data
    log.info(f"   Downloading data for {len(ranked)} tickers ({START_DATE} → {END_DATE})...")
    close_df = download_with_retry(ranked, START_DATE, END_DATE)

    if close_df.empty:
        log.error(f"   No data returned for {index_name}. Skipping export.")
        return

    # Keep only tickers that actually have data, in ranked order
    available = [t for t in ranked if t in close_df.columns]
    close_df  = close_df[available]

    # Step 7: transpose → tickers on rows, dates on columns
    df_wide = close_df.transpose()
    df_wide.columns = pd.to_datetime(df_wide.columns).strftime("%Y-%m-%d")

    filename = os.path.join(OUTPUT_DIR, f"{country}_{index_name}_{len(available)}_tickers.csv")
    df_wide.to_csv(filename)
    log.info(f"   ✓ Saved: {filename}  ({df_wide.shape[0]} tickers × {df_wide.shape[1]} days)")


