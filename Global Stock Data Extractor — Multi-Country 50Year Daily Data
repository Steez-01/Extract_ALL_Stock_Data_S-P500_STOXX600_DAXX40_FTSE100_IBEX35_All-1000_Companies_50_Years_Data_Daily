if __name__ == "__main__":
    import argparse

    parser = argparse.ArgumentParser(description="Global Stock Data Extractor")
    parser.add_argument(
        "--country", type=str, default=None,
        help="Run for a single country only (e.g. --country Germany)"
    )
    parser.add_argument(
        "--sequential", action="store_true",
        help="Disable parallel processing (useful for debugging)"
    )
    args = parser.parse_args()

    if args.country:
        run_single(args.country)
    else:
        run_all(COUNTRY_JOBS, parallel=not args.sequential)
